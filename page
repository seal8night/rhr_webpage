<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css?family=Domine"
      rel="stylesheet"
    />
    <title>Weekday Programs</title>
    <style type="text/css">
      body {
        background-color: #171717;
        font-family: "Domine";
        font-size: 22px;
        color: #d4d4d4;
      }
      a:link {
        color: #d4d4d4;
      }
      a:visited {
        color: #d4d4d4;
      }
      table {
        font-family: Domine, Lato, sans-serif;
        font-size: medium;
        color: #d4d4d4;
      }
      STRONG {
        font-weight: 700;
      }
      th,
      td {
        text-align: center;
        padding: 8px;
      }
      tr:nth-child(even) {
        background-color: #2d2d2d;
      }
    </style>
  </head>
  <body>
    <table style="width: 100%">
      <tr>
        <td>7:00am</td>
        <td>
          <a href="http://www.pastorchuck.org/">The Word For Today WEEKEND</a>
        </td>
        <td>Chuck Smith</td>
      </tr>
      <tr>
        <td>10:30am</td>
        <td>
          <a href="http://www.calvarychapelgrangeville.com/"
            >LIVE Service - Calvary Chapel Grangeville</a
          >
        </td>
        <td>Dean Huibregtse</td>
      </tr>
      <tr>
        <td>3:00pm</td>
        <td>
          <a href="https://hischannel.com/WorldNewsBriefing"
            >World News Briefing</a
          >
        </td>
        <td>Tom Hughes</td>
      </tr>
      <tr>
        <td>5:00pm</td>
        <td>
          <a href="https://countdown2eternity.com/">Countdown to Eternity</a>
        </td>
        <td>James Kaddis and Don Stewart</td>
      </tr>
      <tr>
        <td>10:00pm</td>
        <td><a href="https://ccfingerlakes.org/">Walk In The Light</a></td>
        <td>Bill Gallatin</td>
      </tr>
    </table>
  </body>
</html>
